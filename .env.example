# EmailJS Configuration for Admin Notifications

# Get these from your EmailJS account at https://www.emailjs.com

# EmailJS Service ID (e.g., service_abc123...)
VITE_EMAILJS_SERVICE_ID=your_service_id

# EmailJS Public Key (starts with "xyz_...")
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Admin Email (emails will be sent to this address when someone contacts you)
VITE_ADMIN_EMAIL=your_email@gmail.com

# EmailJS Template ID for admin notifications (when someone submits the contact form)
VITE_EMAILJS_ADMIN_TEMPLATE_ID=your_admin_template_id

# EmailJS Template ID for user confirmation emails (confirmation to the person who contacted)
VITE_EMAILJS_CONFIRM_TEMPLATE_ID=your_confirm_template_id

# Supabase Configuration (if not already set)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_key
